  <property name="styleSheet">
   <string notr="true">/* Estilo general de la ventana de diálogo de Infijas */
QDialog {
    background-color: #1a1a1e;
    color: #ffffff;
    font-family: 'Segoe UI', Arial, sans-serif;
}

/* Estilo para las etiquetas de texto generales */
QLabel {
    color: #e0e0e0;
    font-size: 13px;
    font-weight: bold;
}

/* Estilo para la caja donde el usuario escribe la expresión matemática */
QLineEdit#txt_infija {
    background-color: #25252c;
    border: 2px solid #3f3f46;
    border-radius: 6px;
    padding: 8px;
    color: #ffffff;
    font-size: 15px;
    font-family: 'Consolas', 'Courier New', monospace; /* Fuente matemática clara */
    selection-background-color: #7c4dff;
}
QLineEdit#txt_infija:focus {
    border: 2px solid #7c4dff; /* Brillo morado al escribir */
    background-color: #2a2a35;
}

/* Estilo para el botón de Calcular */
QPushButton#btn_calcular {
    background-color: #7c4dff;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: bold;
}
QPushButton#btn_calcular:hover {
    background-color: #651fff;
}
QPushButton#btn_calcular:pressed {
    background-color: #536dfe;
}

/* Estilo especial para el cuadro que muestra el resultado posfijo */
QLabel#lbl_resultado {
    background-color: #212121;
    border: 2px dashed #7c4dff; /* Línea discontinua para que parezca una zona de resultado */
    border-radius: 6px;
    padding: 12px;
    color: #00e5ff; /* Color cian neón para resaltar el resultado final */
    font-family: 'Consolas', 'Courier New', monospace;
    font-size: 18px;
    letter-spacing: 2px; /* Separa un poco los caracteres para notar los espacios */
}</string>
