  <property name="styleSheet">
   <string notr="true">/* Fondo del diálogo principal */
QDialog {
    background-color: #f8fafc;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
}

/* Estilo general para etiquetas de texto (Labels) */
QLabel {
    color: #334155;
    font-size: 13px;
    font-weight: 500;
}

/* Títulos o etiquetas destacadas */
QLabel#lbl_total_pendientes {
    font-size: 14px;
    font-weight: bold;
    color: #0f766e; /* Verde azulado oscuro */
}

/* Caja de mensajes de estado */
QLabel#lbl_mensajes {
    background-color: #f1f5f9;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 8px;
    color: #1e293b;
    font-size: 12px;
}

/* Campos de texto y SpinBox */
QLineEdit, QSpinBox {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 5px;
    padding: 5px 10px;
    color: #1e293b;
    font-size: 13px;
}

QLineEdit:focus, QSpinBox:focus {
    border: 2px solid #0d9488; /* Enfoque color teal */
    background-color: #f0fdfa;
}

/* Estilo para los botones */
QPushButton {
    background-color: #0d9488; /* Teal principal */
    color: #ffffff;
    border: none;
    border-radius: 5px;
    font-size: 13px;
    font-weight: bold;
    padding: 6px;
}

QPushButton:hover {
    background-color: #0f766e; /* Teal más oscuro al pasar el cursor */
}

QPushButton:pressed {
    background-color: #115e59;
}

/* Botón de &quot;Imprimir Siguiente&quot; destacado (acción principal) */
QPushButton#btn_imprimir {
    background-color: #0284c7; /* Azul */
    font-size: 14px;
}

QPushButton#btn_imprimir:hover {
    background-color: #0369a1;
}

/* Botón de &quot;Consultar Frente&quot; secundario */
QPushButton#btn_frente {
    background-color: #64748b; /* Gris pizarra */
}

QPushButton#btn_frente:hover {
    background-color: #475569;
}

/* Estilo de la Tabla (QTableWidget) */
QTableWidget {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    gridline-color: #f1f5f9;
    border-radius: 6px;
    color: #334155;
    font-size: 12px;
}

QHeaderView::section {
    background-color: #0f766e;
    color: #ffffff;
    padding: 6px;
    font-weight: bold;
    border: none;
    font-size: 12px;
}

QTableWidget::item {
    padding: 5px;
}

QTableWidget::item:selected {
    background-color: #ccfbf1;
    color: #0f766e;
}</string>
