  <property name="styleSheet">
   <string notr="true">/* Estilo general de la ventana de diálogo */
QDialog {
    background-color: #1e1e24;
    color: #ffffff;
    font-family: 'Segoe UI', Arial, sans-serif;
}

/* Estilo para las etiquetas de texto (Labels) */
QLabel {
    color: #f5f5f5;
    font-size: 13px;
    font-weight: bold;
}

/* Estilo específico para resaltar el resultado de la pila */
QLabel#lbl_resultado {
    background-color: #2a2a32;
    border: 2px solid #007acc;
    border-radius: 6px;
    padding: 10px;
    color: #00efff;
    font-family: 'Consolas', monospace;
    font-size: 16px;
}

/* Estilo para la caja de texto (Input) */
QLineEdit {
    background-color: #2d2d38;
    border: 1px solid #4a4a5a;
    border-radius: 4px;
    padding: 6px;
    color: #ffffff;
    font-size: 13px;
    selection-background-color: #007acc;
}
QLineEdit:focus {
    border: 1px solid #007acc;
}

/* Estilo base para TODOS los botones */
QPushButton {
    background-color: #2d2d38;
    color: #ffffff;
    border: 1px solid #4a4a5a;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 13px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #3a3a4a;
    border: 1px solid #007acc;
}
QPushButton:pressed {
    background-color: #1e1e24;
}

/* Estilos específicos para destacar botones por su función */
QPushButton#btn_push {
    background-color: #0e639c;
    border: 1px solid #007acc;
}
QPushButton#btn_push:hover {
    background-color: #1177bb;
}

QPushButton#btn_pop {
    background-color: #a82020;
    border: 1px solid #cc2424;
}
QPushButton#btn_pop:hover {
    background-color: #c42b2b;
}

/* Botones secundarios (Top y Print) */
QPushButton#btn_top, QPushButton#btn_print {
    background-color: #33333d;
    color: #00efff;
    border: 1px solid #00efff;
}
QPushButton#btn_top:hover, QPushButton#btn_print:hover {
    background-color: #00efff;
    color: #1e1e24;
}</string>
