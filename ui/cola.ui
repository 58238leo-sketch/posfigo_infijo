  <property name="styleSheet">
   <string notr="true">/* Estilo general de la ventana de diálogo de Colas */
QDialog {
    background-color: #12181a;
    color: #ffffff;
    font-family: 'Segoe UI', Arial, sans-serif;
}

/* Estilo para las etiquetas de texto generales */
QLabel {
    color: #e2e8f0;
    font-size: 13px;
    font-weight: bold;
}

/* Estilo para la zona donde se dibuja el flujo de la cola */
QLabel#lbl_resultado {
    background-color: #1a2324;
    border: 2px solid #0d9488; /* Borde verde esmeralda */
    border-radius: 6px;
    padding: 12px;
    color: #2dd4bf; /* Texto verde brillante/neón */
    font-family: 'Consolas', monospace;
    font-size: 16px;
}

/* Estilo para la caja de texto (Input de datos) */
QLineEdit#txt_dato {
    background-color: #1e293b;
    border: 1px solid #475569;
    border-radius: 4px;
    padding: 6px;
    color: #ffffff;
    font-size: 13px;
}
QLineEdit#txt_dato:focus {
    border: 1px solid #0d9488;
}

/* Estilo base para TODOS los botones */
QPushButton {
    background-color: #1e293b;
    color: #ffffff;
    border: 1px solid #475569;
    border-radius: 5px;
    padding: 8px 15px;
    font-size: 13px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #334155;
    border: 1px solid #0d9488;
}
QPushButton:pressed {
    background-color: #0f172a;
}

/* Botón ENQUEUE (Insertar al final - Color de éxito/flujo) */
QPushButton#btn_enqueue {
    background-color: #0f766e;
    border: 1px solid #0d9488;
}
QPushButton#btn_enqueue:hover {
    background-color: #115e59;
}

/* Botón DEQUEUE (Sacar del frente - Color de salida) */
QPushButton#btn_dequeue {
    background-color: #991b1b;
    border: 1px solid #b91c1c;
}
QPushButton#btn_dequeue:hover {
    background-color: #7f1d1d;
}

/* Botones de consulta específicos (btn_first, btn_last, btn_print) */
QPushButton#btn_first, QPushButton#btn_last, QPushButton#btn_print {
    background-color: #115e59;
    color: #2dd4bf;
    border: 1px solid #2dd4bf;
}
QPushButton#btn_first:hover, QPushButton#btn_last:hover, QPushButton#btn_print:hover {
    background-color: #2dd4bf;
    color: #12181a;
}</string>
  </property>
